{
  "manager": {
    "name": "Iran-Node",
    "host": "0.0.0.0",
    "port": 7001,
    "public_host": "IRAN_NODE_PUBLIC_IP_OR_DNS",
    "api_token": "CHANGE_ME_SECRET_TOKEN",
    "log_file": "./logs/iran-node.log"
  },
  "groups": [
    {
      "name": "Iran-Node-Group-1",
      "process_count": 3,
      "listen_host": "0.0.0.0",
      "port_mode": "random",
      "targets": [{"type": "remote_group", "dependency": "Gateway-Node-Group-1"}],
      "strategy": "round_robin",
      "enabled": true
    },
    {
      "name": "Iran-Node-Group-2",
      "process_count": 4,
      "listen_host": "0.0.0.0",
      "port_mode": "random",
      "targets": [{"type": "remote_group", "dependency": "Gateway-Node-Group-2"}],
      "strategy": "round_robin",
      "enabled": true
    },
    {
      "name": "Iran-Node-Group-3",
      "process_count": 5,
      "listen_host": "0.0.0.0",
      "port_mode": "random",
      "targets": [{"type": "remote_group", "dependency": "Gateway-Node-Group-3"}],
      "strategy": "round_robin",
      "enabled": true
    },
    {
      "name": "Iran-Node-Group-Sub",
      "process_count": 1,
      "listen_host": "0.0.0.0",
      "port_mode": "random",
      "targets": [{"type": "remote_group", "dependency": "Gateway-Node-Group-Sub"}],
      "strategy": "round_robin",
      "enabled": true
    }
  ],
  "remote_dependencies": [
    {
      "name": "Gateway-Node-Group-1",
