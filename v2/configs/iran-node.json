      "group_name": "Gateway-Node-Group-3",
      "token": "CHANGE_ME_SECRET_TOKEN",
      "sync_interval_seconds": 10
    },
    {
      "name": "Gateway-Node-Group-Sub",
      "manager_url": "http://GATEWAY_NODE_PUBLIC_IP_OR_DNS:7002",
